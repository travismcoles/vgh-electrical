# Copy this file to .env and fill in your values

# Database - SQLite (recommended for Raspberry Pi)
# The file will be created automatically
DATABASE_URL="file:./data/panels.db"

# NextAuth - Generate a strong secret:
#   openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_STRING"

# Your app URL (no trailing slash)
# For local: http://localhost:3000
# For Pi on local network: http://192.168.1.XXX:3000
# For domain: https://panels.yourhospital.ca
NEXTAUTH_URL="http://localhost:3000"

# Where uploaded files are stored (default: ./uploads inside app folder)
# UPLOAD_DIR="/data/uploads"

# Optional: email for future notifications
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your@email.com"
# SMTP_PASS="yourpassword"
# NOTIFY_EMAIL="travis.coles@vch.ca"
